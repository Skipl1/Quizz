{
  "general": {
    "vimMode": false,
    "preferredEditor": "code"
  },
  "ui": {
    "theme": "GitHub",
    "hideTips": false,
    "customWittyPhrases": [
      "Архитектура — это искусство того, что нельзя забыть",
      "Квиз сам себя не адаптирует, но мы поможем",
      "Подключение к ИИ-оркестратору..."
    ]
  },
  "tools": {
    "approvalMode": "yolo",
    "sandbox": "docker",
    "exclude": []
  },
  "mcpServers": {},
  "model": {
    "name": "coder-model",
    "maxSessionTurns": 100,
    "enableOpenAILogging": false
    },
  "context": {
    "fileName": [ "QWEN.md",".qwen/agents/*.md" ],
    "includeDirectories": [
      "public"
    ],
    "loadFromIncludeDirectories": true,
    "fileFiltering": {
      "respectGitIgnore": true
    }
  },
  "advanced": {
    "excludedEnvVars": [
      "DEBUG",
      "NODE_ENV"
    ]
  },
  "$version": 3
}