# Скопируйте в .env и заполните. Для Render задайте переменные в панели сервиса.
# Docker Compose читает этот же файл из корня проекта для подстановки POSTGRES_*.

# --- База данных (обязательно в продакшене) ---
# Строка подключения к PostgreSQL (в т.ч. к контейнеру на вашем сервере)
DATABASE_URL=postgresql://quiz:password@your-server.example.com:5432/quiz

# Учётные данные контейнера Postgres (docker compose); пароль должен совпадать с DATABASE_URL
POSTGRES_USER=quiz
POSTGRES_PASSWORD=замените_на_длинный_случайный_пароль
POSTGRES_DB=quiz
# Порт на хосте (если 5432 занят: POSTGRES_PUBLISH_PORT=15432)
POSTGRES_PUBLISH_PORT=5432

# SSL для node-pg: для Docker без TLS укажите false. Для облачных БД с TLS обычно true
DATABASE_SSL=false

# Если true — строгая проверка TLS (нужен валидный сертификат на стороне БД)
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Пул соединений (опционально)
DATABASE_POOL_MAX=5
DATABASE_CONNECTION_TIMEOUT_MS=60000
DATABASE_IDLE_TIMEOUT_MS=60000
DATABASE_STATEMENT_TIMEOUT_MS=30000

# --- Админ-панель ---
ADMIN_LOGIN=admin
ADMIN_PASSWORD=замените_на_надёжный_пароль

# --- HTTP-сервер ---
PORT=3000
NODE_ENV=production

# За прокси Render / nginx — нужно для корректного rate limit по IP клиента
TRUST_PROXY=true

# Длительность вопроса по умолчанию (секунды), если не задана у вопроса
QUESTION_TIME_SECONDS=30

# --- Лимиты HTTP (express-rate-limit) ---
HTTP_RATE_WINDOW_MS=300000
HTTP_RATE_MAX=1000

# --- Лимиты Socket.IO ---
SOCKET_RATE_WINDOW_MS=15000
SOCKET_RATE_MAX_EVENTS=100
SOCKET_RATE_WARN_THRESHOLD=60
